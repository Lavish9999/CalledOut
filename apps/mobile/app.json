{
  "expo": {
    "name": "CalledOut",
    "slug": "calledout",
    "scheme": "calledout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.calledout.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "CalledOut uses the camera to capture fresh workout proof.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.calledout.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CalledOut to capture fresh workout proof."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "defaultChannel": "commitments"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5af3d147-8b05-425c-92f6-ec54f00d3d86"
      }
    },
    "owner": "lavish999",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5af3d147-8b05-425c-92f6-ec54f00d3d86"
    }
  }
}
