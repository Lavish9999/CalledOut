# Public Expo variables. The Supabase publishable key is safe in the app only with RLS enabled.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_REPLACE_ME
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_REPLACE_ME
EXPO_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_SUPPORT_EMAIL=support@your-domain.com

# Supabase Edge Function secrets — set with `supabase secrets set`; never expose them in the app.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
REVENUECAT_WEBHOOK_AUTH=REPLACE_ME
EXPO_ACCESS_TOKEN=REPLACE_ME
MEDIA_MODERATION_API_KEY=REPLACE_ME
DEADLINE_JOB_SECRET=REPLACE_WITH_A_LONG_RANDOM_VALUE
NOTIFICATION_JOB_SECRET=REPLACE_WITH_A_DIFFERENT_LONG_RANDOM_VALUE
ACCOUNT_DELETION_JOB_SECRET=REPLACE_WITH_A_THIRD_LONG_RANDOM_VALUE
